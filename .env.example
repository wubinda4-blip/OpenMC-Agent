# Default LLM model. zhipu models use the built-in HTTP adapter.
OPENMC_AGENT_MODEL=zhipu:glm-5.2

# Provider keys. Set only the providers you plan to use.
ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPUAI_TIMEOUT_SECONDS=180
ZHIPUAI_MAX_RETRIES=2
DEEPSEEK_API_KEY=
DEEPSEEK_TIMEOUT_SECONDS=180
DEEPSEEK_MAX_RETRIES=2
# DeepSeek via SenseNova (provider prefix: ds, e.g. ds:deepseek-v4-flash)
SENSENOVA_API_KEY=
SENSENOVA_TIMEOUT_SECONDS=180
SENSENOVA_MAX_RETRIES=2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional local model endpoint.
OLLAMA_BASE_URL=http://localhost:11434

# Optional runtime path to mounted OpenMC nuclear data in cloud containers.
OPENMC_CROSS_SECTIONS=

# Streaming/heartbeat defaults for long cloud LLM calls.
OPENMC_AGENT_STREAM=1
OPENMC_AGENT_LLM_HEARTBEAT_SECONDS=10
